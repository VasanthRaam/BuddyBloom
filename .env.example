# Supabase Configuration
SUPABASE_URL=your-supabase-project-url
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Database Configuration (PostgreSQL string from Supabase, switch to asyncpg)
# e.g., postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://user:password@localhost/dbname

# App Configuration
PROJECT_NAME="BuddyBloom API"
VERSION="1.0.0"
API_V1_STR="/api/v1"
